{
  "info": {
    "name": "Smart Flower Pot",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url", "value": "http://localhost:3001" },
    { "key": "user_token", "value": "" },
    { "key": "device_token", "value": "" },
    { "key": "profile_id", "value": "" },
    { "key": "device_id", "value": "" }
  ],
  "item": [
    {
      "name": "Health Check",
      "request": {
        "method": "GET",
        "url": "{{base_url}}/health"
      }
    },
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.token) pm.collectionVariables.set('user_token', json.token);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{base_url}}/api/auth/register",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"testuser\",\n  \"email\": \"test@example.com\",\n  \"name\": \"Test\",\n  \"surname\": \"User\",\n  \"password\": \"password123\"\n}"
            }
          }
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.token) pm.collectionVariables.set('user_token', json.token);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{base_url}}/api/auth/login",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"test@example.com\",\n  \"password\": \"password123\"\n}"
            }
          }
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{user_token}}" }
            ],
            "url": "{{base_url}}/api/auth/logout"
          }
        }
      ]
    },
    {
      "name": "Users",
      "item": [
        {
          "name": "Add Device",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "const devices = json.devices;",
                  "if (devices && devices.length > 0) {",
                  "  const last = devices[devices.length - 1];",
                  "  pm.collectionVariables.set('device_id', last.deviceId);",
                  "  pm.collectionVariables.set('device_token', last.token);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{user_token}}" }
            ],
            "url": "{{base_url}}/api/users/devices",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Flower Pot Living Room\"\n}"
            }
          }
        },
        {
          "name": "Get Devices",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{user_token}}" }
            ],
            "url": "{{base_url}}/api/users/devices"
          }
        },
        {
          "name": "Regenerate Device Token",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{user_token}}" }
            ],
            "url": "{{base_url}}/api/users/devices/{{device_id}}/regenerate-token"
          }
        },
        {
          "name": "Set Device Profile",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{user_token}}" }
            ],
            "url": "{{base_url}}/api/users/devices/{{device_id}}/profile",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"profileId\": \"{{profile_id}}\"\n}"
            }
          }
        },
        {
          "name": "Remove Device Profile",
          "request": {
            "method": "DELETE",
            "header": [
              { "key": "Authorization", "value": "Bearer {{user_token}}" }
            ],
            "url": "{{base_url}}/api/users/devices/{{device_id}}/profile"
          }
        }
      ]
    },
    {
      "name": "Flower Profiles",
      "item": [
        {
          "name": "Create Profile",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.profile && json.profile._id) {",
                  "  pm.collectionVariables.set('profile_id', json.profile._id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{user_token}}" }
            ],
            "url": "{{base_url}}/api/profiles",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"flowerName\": \"Monstera deliciosa\",\n  \"public\": true,\n  \"temp\": { \"ok\": [18, 27], \"warn\": [12, 32] },\n  \"humidity\": { \"ok\": [50, 70], \"warn\": [35, 80] },\n  \"light\": { \"ok\": [500, 10000], \"warn\": [200, 20000] }\n}"
            }
          }
        },
        {
          "name": "Get Profiles (own + public)",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{user_token}}" }
            ],
            "url": "{{base_url}}/api/profiles"
          }
        },
        {
          "name": "Get Profile by ID",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{user_token}}" }
            ],
            "url": "{{base_url}}/api/profiles/{{profile_id}}"
          }
        },
        {
          "name": "Update Profile",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{user_token}}" }
            ],
            "url": "{{base_url}}/api/profiles/{{profile_id}}",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"flowerName\": \"Monstera deliciosa (updated)\",\n  \"public\": false,\n  \"temp\": { \"ok\": [18, 27], \"warn\": [12, 32] },\n  \"humidity\": { \"ok\": [50, 70], \"warn\": [35, 80] },\n  \"light\": { \"ok\": [500, 10000], \"warn\": [200, 20000] }\n}"
            }
          }
        },
        {
          "name": "Delete Profile",
          "request": {
            "method": "DELETE",
            "header": [
              { "key": "Authorization", "value": "Bearer {{user_token}}" }
            ],
            "url": "{{base_url}}/api/profiles/{{profile_id}}"
          }
        }
      ]
    },
    {
      "name": "IoT",
      "item": [
        {
          "name": "Post Reading",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{base_url}}/api/iot/readings",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"token\": \"{{device_token}}\",\n  \"airTemp\": 22.5,\n  \"airMoisture\": 55,\n  \"light\": 3200,\n  \"uvIndex\": 3,\n  \"soilMoisture\": 65\n}"
            }
          }
        },
        {
          "name": "Get Readings",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{user_token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/api/iot/readings?deviceId={{device_id}}",
              "query": [{ "key": "deviceId", "value": "{{device_id}}" }]
            }
          }
        }
      ]
    }
  ]
}