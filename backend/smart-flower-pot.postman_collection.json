{
  "info": {
    "name": "Smart Flower Pot",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url", "value": "http://localhost:3001" },
    { "key": "user_token", "value": "" },
    { "key": "device_token", "value": "" }
  ],
  "item": [
    {
      "name": "Health Check",
      "request": {
        "method": "GET",
        "url": "{{base_url}}/health"
      }
    },
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.token) pm.collectionVariables.set('user_token', json.token);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{base_url}}/api/auth/register",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"testuser\",\n  \"email\": \"test@example.com\",\n  \"name\": \"Test\",\n  \"surname\": \"User\",\n  \"password\": \"password123\"\n}"
            }
          }
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.token) pm.collectionVariables.set('user_token', json.token);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{base_url}}/api/auth/login",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"test@example.com\",\n  \"password\": \"password123\"\n}"
            }
          }
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{user_token}}" }
            ],
            "url": "{{base_url}}/api/auth/logout"
          }
        }
      ]
    },
    {
      "name": "Users",
      "item": [
        {
          "name": "Add Device",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{user_token}}" }
            ],
            "url": "{{base_url}}/api/users/devices",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Flower Pot Living Room\"\n}"
            }
          }
        },
        {
          "name": "Get Devices",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{user_token}}" }
            ],
            "url": "{{base_url}}/api/users/devices"
          }
        },
        {
          "name": "Regenerate Device Token",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{user_token}}" }
            ],
            "url": "{{base_url}}/api/users/devices/:deviceId/regenerate-token"
          }
        }
      ]
    },
    {
      "name": "IoT",
      "item": [
        {
          "name": "Post Reading",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{base_url}}/api/iot/readings",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"token\": \"{{device_token}}\",\n  \"airTemp\": 22.5,\n  \"airMoisture\": 55,\n  \"light\": 3200,\n  \"uvIndex\": 3,\n  \"soilMoisture\": 65\n}"
            }
          }
        },
        {
          "name": "Get Readings",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{user_token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/api/iot/readings?deviceId=",
              "query": [{ "key": "deviceId", "value": "" }]
            }
          }
        }
      ]
    }
  ]
}
